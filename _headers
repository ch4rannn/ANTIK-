# Cache assets for 1 year
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
/assets/posters/*
  Cache-Control: public, max-age=31536000, immutable
/assets/videos/*
  Cache-Control: public, max-age=31536000, immutable
/styles.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400
/script.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400
/*.mp4
  Cache-Control: public, max-age=31536000, immutable
